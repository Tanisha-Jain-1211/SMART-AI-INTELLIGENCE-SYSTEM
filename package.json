{
  "name": "smart-complaint-system",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:ml": "cd ml-service && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently -n backend,frontend,ml \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:ml\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
